# Atelier Supply AI Platform — environment

# OpenAI API key. Leave empty to run entirely in mock mode.
# Never commit a real key; never expose it to the client.
OPENAI_API_KEY=

# Image generation provider: "openai" or "mock".
# If set to "openai" but OPENAI_API_KEY is empty, the app falls back to mock.
AI_IMAGE_PROVIDER=mock

# Text/report provider. Only "mock" is implemented today (architecture placeholder).
AI_TEXT_PROVIDER=mock

# OpenAI image model. The brief specifies gpt-image-2; the currently shipping
# model is gpt-image-1 — set whichever your account has access to.
OPENAI_IMAGE_MODEL=gpt-image-2

# Image quality: low | medium | high | auto
OPENAI_IMAGE_QUALITY=medium

# Image size: 1024x1024 | 1536x1024 | 1024x1536 | auto
OPENAI_IMAGE_SIZE=1536x1024

# Vision model for the post-generation design analysis (must support images).
# Used to read the generated image and report exactly what is visible.
OPENAI_VISION_MODEL=gpt-4o-mini
